{
  "name": "@benjadiazp/procedural-art",
  "version": "0.1.0",
  "description": "GPU-accelerated procedural art simulations built with Three.js",
  "type": "module",
  "main": "./dist/procedural-art.js",
  "module": "./dist/procedural-art.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/procedural-art.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "BUILD_LIB=true vite build && tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "test": "bunx playwright test --reporter=list",
    "test:headed": "bunx playwright test --headed"
  },
  "peerDependencies": {
    "three": ">=0.160.0",
    "lil-gui": ">=0.19.0",
    "postprocessing": ">=6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.183.1",
    "lil-gui": "^0.21.0",
    "postprocessing": "^6.39.0",
    "puppeteer": "^24.40.0",
    "three": "^0.183.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
